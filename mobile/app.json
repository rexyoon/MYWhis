{
  "expo": {
    "name": "MyWhis",
    "slug": "mywhis",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mywhis",
    "userInterfaceStyle": "dark",
    "splash": { "backgroundColor": "#1a1410" },
