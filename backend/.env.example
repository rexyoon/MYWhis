# DB 연결 (로컬 Postgres 또는 Supabase Postgres)
# Supabase 사용 시: Project Settings > Database > Connection string 참고
DB_URL=jdbc:postgresql://localhost:5432/mywhis
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT 서명 시크릿 (32바이트 이상 긴 랜덤 문자열)
JWT_SECRET=change-me-to-a-very-long-random-secret-at-least-32-bytes
# Gemini API 키 (https://aistudio.google.com/apikey 에서 발급, 나중에 채우면 됨
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
